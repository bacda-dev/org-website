# ─────────────────────────────────────────────────────────────────────────
#  BACDA Website — environment template
#  Copy to .env.local (NEVER commit .env.local) and fill values.
# ─────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ──────────────────────────────────────────────────
# Local dev: values printed by `npx supabase start`.
# Production: values from Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (required for contact form in production) ─────────────────────
# Generate at resend.com/api-keys. FROM address must use a verified domain.
# If unset, contact-form submissions are logged and written to DB, but no email is sent.
RESEND_API_KEY=
RESEND_FROM_EMAIL=BACDA <noreply@bayareacreativedancers.org>
RESEND_TO_EMAIL=contactus@bayareacreativedancers.org

# ── Site (required) ──────────────────────────────────────────────────────
# Used for canonical URLs, OG images, sitemap.
# Local: http://localhost:3000
# Staging: https://new.bayareacreativedancers.org
# Production: https://bayareacreativedancers.org
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Instagram oEmbed (optional) ──────────────────────────────────────────
# From a Facebook app with oEmbed product enabled. Needed only if the admin
# wants Instagram post thumbnails to auto-fetch. Without this, admins enter
# thumbnail URLs manually.
FB_OEMBED_TOKEN=

# ── Sentry (optional) ────────────────────────────────────────────────────
# Production error tracking. Free tier is plenty for a non-profit site.
SENTRY_DSN=

# ── Deliberately NOT used ────────────────────────────────────────────────
# Per user directive #8 (no Google Cloud Console), the following are
# intentionally omitted and should NOT be added:
#   YOUTUBE_API_KEY     — YouTube content is admin-curated, no Data API call
#   GOOGLE_MAPS_API_KEY — Contact page uses no-API-key Maps iframe embed
#   MAILCHIMP_API_KEY   — No newsletter feature
#   NEXT_PUBLIC_PLAUSIBLE_DOMAIN — No analytics in v1
